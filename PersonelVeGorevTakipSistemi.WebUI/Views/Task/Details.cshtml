@model PersonelVeGorevTakipSistemi.Core.Entities.Task
@using PersonelVeGorevTakipSistemi.Core.Enums

@{
    ViewData["Title"] = Model.Title + " - Görev Detayları";
    bool isYönetici = User.IsInRole("Yönetici");
    bool isOverdue = Model.DueDate < DateTime.Today && Model.Status != TaskState.Completed;
}

<div class="container mt-4">
    <!-- Geri Don ve Duzenle Butonlari -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary px-3">
            <i class="bi bi-arrow-left me-1"></i> Panoya Geri Dön
        </a>
        @if (isYönetici)
        {
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-3">
                    <i class="bi bi-pencil-square me-1"></i> Görevi Düzenle
                </a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bu görevi silmek istediğinizden emin misiniz?');">
                    <button type="submit" class="btn btn-outline-danger px-3">
                        <i class="bi bi-trash me-1"></i> Görevi Sil
                    </button>
                </form>
            </div>
        }
    </div>

    <!-- Mesaj Bildirimleri -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <div class="row g-4">
        <!-- SOL SÜTUN: GÖREV DETAYI VE DOSYA YÖNETİMİ -->
        <div class="col-lg-8">
            <!-- Görev Detay Karti -->
            <div class="card shadow-sm border-0 rounded-3 mb-4 bg-white">
                <div class="card-body p-4">
                    <h3 class="fw-bold text-dark mb-3">@Model.Title</h3>
                    <p class="text-secondary" style="font-size: 15px; line-height: 1.6; white-space: pre-line;">
                        @Model.Description
                    </p>
                </div>
            </div>

            <!-- Dosya Yukleme ve Listeleme Karti -->
            <div class="card shadow-sm border-0 rounded-3 bg-white">
                <div class="card-header bg-light py-3 border-0">
                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-paperclip me-2 text-primary"></i> Görev Dosyaları</h5>
                </div>
                <div class="card-body p-4">
                    
                    <!-- 1. Dosya Yukleme Formu -->
                    <form asp-action="UploadFile" asp-controller="Task" method="post" enctype="multipart/form-data" class="mb-4 p-3 bg-light rounded-3 border">
                        <input type="hidden" name="taskId" value="@Model.Id" />
                        <label class="form-label text-dark fw-bold mb-2">Yeni Dosya Yükle</label>
                        <div class="input-group">
                            <input type="file" name="file" class="form-control" required />
                            <button type="submit" class="btn btn-primary">Dosyayı Yükle</button>
                        </div>
                        <div class="form-text text-muted small mt-2">
                            * İzin verilen formatlar: <strong>PDF, JPG, JPEG, PNG, GIF</strong>. Maksimum boyut: <strong>5 MB</strong>.
                        </div>
                    </form>

                    <!-- 2. Yuklenmis Dosyalar Listesi -->
                    <label class="form-label text-dark fw-bold mb-3">Yüklenen Dosyalar (@Model.TaskFiles.Count)</label>
                    
                    @if (Model.TaskFiles == null || !Model.TaskFiles.Any())
                    {
                        <div class="text-center py-4 bg-light rounded-3 text-secondary small">
                            Bu göreve henüz herhangi bir dosya yüklenmemiştir.
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush border rounded-3">
                            @foreach (var file in Model.TaskFiles)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                                    <div class="d-flex align-items-center">
                                        <!-- Dosya Tipine Gore Icon Belirleme -->
                                        @if (file.ContentType.Contains("pdf"))
                                        {
                                            <i class="bi bi-file-earmark-pdf-fill text-danger fs-3 me-3"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-file-earmark-image-fill text-primary fs-3 me-3"></i>
                                        }
                                        <div>
                                            <span class="fw-bold text-dark d-block">@file.FileName</span>
                                            <span class="text-muted small">Yükleme: @file.UploadedDate.ToString("dd.MM.yyyy HH:mm")</span>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <!-- Indir Butonu -->
                                        <a asp-action="DownloadFile" asp-route-id="@file.Id" class="btn btn-sm btn-outline-secondary px-3">
                                            İndir
                                        </a>
                                        <!-- Sil Butonu -->
                                        <form asp-action="DeleteFile" asp-route-id="@file.Id" method="post" onsubmit="return confirm('Bu dosyayı silmek istediğinizden emin misiniz?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                Sil
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- SAĞ SÜTUN: KÜNYE BİLGİLERİ -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-3 bg-white">
                <div class="card-header bg-light py-3 border-0">
                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-info-circle me-2 text-primary"></i> Görev Künyesi</h5>
                </div>
                <div class="card-body p-4">
                    <!-- Durum Bilgisi -->
                    <div class="mb-3">
                        <span class="text-secondary small d-block mb-1">Görevin Durumu</span>
                        @if (Model.Status == TaskState.Pending)
                        {
                            <span class="badge bg-secondary px-3 py-2 fs-6">Yapılacak</span>
                        }
                        else if (Model.Status == TaskState.InProgress)
                        {
                            <span class="badge bg-warning text-dark px-3 py-2 fs-6">Yapılıyor</span>
                        }
                        else if (Model.Status == TaskState.Completed)
                        {
                            <span class="badge bg-success px-3 py-2 fs-6">Tamamlandı</span>
                        }
                    </div>

                    <!-- Oncelik Bilgisi -->
                    <div class="mb-3">
                        <span class="text-secondary small d-block mb-1">Öncelik Derecesi</span>
                        @if (Model.Priority == TaskPriority.Low)
                        {
                            <span class="badge bg-light text-secondary border px-3 py-2 fs-6">Düşük</span>
                        }
                        else if (Model.Priority == TaskPriority.Medium)
                        {
                            <span class="badge bg-warning text-dark px-3 py-2 fs-6">Orta</span>
                        }
                        else if (Model.Priority == TaskPriority.High)
                        {
                            <span class="badge bg-danger text-white px-3 py-2 fs-6">Yüksek</span>
                        }
                    </div>

                    <hr class="my-3 opacity-25" />

                    <!-- Gorev Baslangic Tarihi -->
                    <div class="mb-3">
                        <span class="text-secondary small d-block">Oluşturulma Tarihi</span>
                        <span class="text-dark fw-bold">@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>

                    <!-- Gorev Bitis Tarihi -->
                    <div class="mb-3">
                        <span class="text-secondary small d-block">Son Teslim Tarihi</span>
                        <span class="fw-bold @(isOverdue ? "text-danger" : "text-dark")">
                            @Model.DueDate.ToString("dd.MM.yyyy")
                            @if (isOverdue)
                            {
                                <span class="badge bg-danger text-white ms-1" style="font-size: 10px;">Gecikti!</span>
                            }
                        </span>
                    </div>

                    <hr class="my-3 opacity-25" />

                    <!-- Atanan Personel -->
                    <div class="mb-3">
                        <span class="text-secondary small d-block">Sorumlu Personel</span>
                        <span class="text-dark fw-bold d-block">@Model.Employee.FirstName @Model.Employee.LastName</span>
                        <span class="text-muted small">@Model.Employee.Title</span>
                    </div>

                    <!-- Departman -->
                    <div class="mb-2">
                        <span class="text-secondary small d-block">Departman</span>
                        <span class="text-dark fw-bold">@(Model.Employee.Department != null ? Model.Employee.Department.Name : "Belirtilmemiş")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
