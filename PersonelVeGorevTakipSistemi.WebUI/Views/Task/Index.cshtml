@model List<PersonelVeGorevTakipSistemi.Core.Entities.Task>
@using PersonelVeGorevTakipSistemi.Core.Enums
@using TaskState = PersonelVeGorevTakipSistemi.Core.Enums.TaskState

@{
    ViewData["Title"] = "Görev Takip (Kanban)";
    bool isYönetici = User.IsInRole("Yönetici");
}

<div class="container mt-4">
    <!-- Baslik ve Yeni Gorev Ekle Butonu (Sadece Yonetici) -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Görev Panosu</h2>
            <p class="text-secondary small mb-0">Görevlerin süreçlerini Kanban panosu üzerinden takip edin</p>
        </div>
        @if (isYönetici)
        {
            <a asp-action="Create" asp-controller="Task" class="btn btn-primary px-4 py-2">
                <i class="bi bi-plus-square me-1"></i> Yeni Görev Oluştur
            </a>
        }
    </div>

    <!-- Mesaj Bildirimleri -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <!-- Filtreleme Paneli -->
    <div class="card shadow-sm border-0 rounded-3 mb-4 bg-light">
        <div class="card-body py-3">
            <form method="get" asp-action="Index" class="row g-3 align-items-center">
                <!-- Oncelik Filtresi -->
                <div class="col-md-3">
                    <label class="form-label text-secondary small fw-bold">Öncelik Derecesi</label>
                    <select name="priority" class="form-select form-select-sm">
                        <option value="">Tümü</option>
                        <option value="Low" selected="@(ViewBag.SelectedPriority?.ToString() == "Low" ? "selected" : null)">Düşük</option>
                        <option value="Medium" selected="@(ViewBag.SelectedPriority?.ToString() == "Medium" ? "selected" : null)">Orta</option>
                        <option value="High" selected="@(ViewBag.SelectedPriority?.ToString() == "High" ? "selected" : null)">Yüksek</option>
                    </select>
                </div>

                <!-- Departman Filtresi (Sadece Yoneticiye gosterilir) -->
                @if (isYönetici)
                {
                    <div class="col-md-3">
                        <label class="form-label text-secondary small fw-bold">Departman</label>
                        <select name="departmentId" class="form-select form-select-sm">
                            <option value="">Tümü</option>
                            @if (ViewBag.Departments != null)
                            {
                                foreach (var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.Id" selected="@(ViewBag.SelectedDepartmentId == dept.Id ? "selected" : null)">@dept.Name</option>
                                }
                            }
                        </select>
                    </div>
                }

                <!-- Durum Filtresi -->
                <div class="col-md-3">
                    <label class="form-label text-secondary small fw-bold">Durum</label>
                    <select name="status" class="form-select form-select-sm">
                        <option value="">Tümü</option>
                        <option value="Pending" selected="@(ViewBag.SelectedStatus?.ToString() == "Pending" ? "selected" : null)">Yapılacak</option>
                        <option value="InProgress" selected="@(ViewBag.SelectedStatus?.ToString() == "InProgress" ? "selected" : null)">Yapılıyor</option>
                        <option value="Completed" selected="@(ViewBag.SelectedStatus?.ToString() == "Completed" ? "selected" : null)">Tamamlandı</option>
                    </select>
                </div>

                <!-- Butonlar -->
                <div class="col-md-3 d-flex align-items-end pt-4">
                    <button type="submit" class="btn btn-sm btn-primary w-50 me-2">Filtrele</button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary w-50">Temizle</a>
                </div>
            </form>
        </div>
    </div>

    <!-- KANBAN PANOSU -->
    <div class="row g-4">
        <!-- 1. SÜTUN: YAPILACAK (PENDING) -->
        <div class="col-lg-4">
            <div class="card h-100 border-0 shadow-sm bg-light" style="min-height: 500px;">
                <div class="card-header bg-white border-top border-secondary border-3 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark mb-0">Yapılacak</h5>
                    <span class="badge bg-secondary text-white rounded-pill">
                        @Model.Count(t => t.Status == TaskState.Pending)
                    </span>
                </div>
                <div class="card-body p-3">
                    <div class="kanban-column-cards" data-status="Pending" style="min-height: 450px;">
                        @foreach (var item in Model.Where(t => t.Status == TaskState.Pending))
                        {
                            @await Html.PartialAsync("_TaskCardPartial", item)
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. SÜTUN: YAPILIYOR (IN PROGRESS) -->
        <div class="col-lg-4">
            <div class="card h-100 border-0 shadow-sm bg-light" style="min-height: 500px;">
                <div class="card-header bg-white border-top border-warning border-3 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark mb-0">Yapılıyor</h5>
                    <span class="badge bg-warning text-dark rounded-pill">
                        @Model.Count(t => t.Status == TaskState.InProgress)
                    </span>
                </div>
                <div class="card-body p-3">
                    <div class="kanban-column-cards" data-status="InProgress" style="min-height: 450px;">
                        @foreach (var item in Model.Where(t => t.Status == TaskState.InProgress))
                        {
                            @await Html.PartialAsync("_TaskCardPartial", item)
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. SÜTUN: TAMAMLANDI (COMPLETED) -->
        <div class="col-lg-4">
            <div class="card h-100 border-0 shadow-sm bg-light" style="min-height: 500px;">
                <div class="card-header bg-white border-top border-success border-3 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark mb-0">Tamamlandı</h5>
                    <span class="badge bg-success text-white rounded-pill">
                        @Model.Count(t => t.Status == TaskState.Completed)
                    </span>
                </div>
                <div class="card-body p-3">
                    <div class="kanban-column-cards" data-status="Completed" style="min-height: 450px;">
                        @foreach (var item in Model.Where(t => t.Status == TaskState.Completed))
                        {
                            @await Html.PartialAsync("_TaskCardPartial", item)
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Sürükle Bırak CSS Stilleri -->
<style>
    .kanban-column-cards {
        padding: 5px;
        border-radius: 8px;
    }
    /* Sürükleme esnasında boş kalan yerin stil tasarımı */
    .sortable-ghost {
        opacity: 0.4;
        border: 2px dashed #d97706 !important;
        background-color: #fdfbf7 !important;
    }
</style>

<!-- SortableJS Kütüphanesi ve Kodları -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Tüm kanban sütunlarını seçiyoruz
        const columns = document.querySelectorAll('.kanban-column-cards');

        columns.forEach(col => {
            new Sortable(col, {
                group: 'kanban', // Sütunların birbiri arasında kart alışverişi yapabilmesini sağlar
                animation: 150,  // Milisaniye cinsinden yumuşak sürükleme animasyonu
                ghostClass: 'sortable-ghost', // Sürüklerken arkada kalan boşluğun sınıfı
                onEnd: function (evt) {
                    const cardEl = evt.item; // Sürüklenen HTML kartı
                    const taskId = cardEl.getAttribute('data-id');
                    const newStatus = evt.to.getAttribute('data-status'); // Kartın bırakıldığı sütunun durumu

                    // Kart farklı bir sütuna bırakıldıysa veritabanını güncelliyoruz
                    if (evt.from !== evt.to) {
                        const formData = new FormData();
                        formData.append('id', taskId);
                        formData.append('status', newStatus);

                        // AJAX isteği gönderiyoruz
                        fetch('/Task/UpdateStatus', {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                // Panodaki sayaçları ve durumları yenilemek için sayfayı tazeliyoruz
                                window.location.reload();
                            } else {
                                alert(data.message || 'Görev durumu güncellenirken bir yetki engeli oluştu.');
                                window.location.reload();
                            }
                        })
                        .catch(err => {
                            console.error(err);
                            window.location.reload();
                        });
                    }
                }
            });
        });
    });
</script>
