@model PersonelVeGorevTakipSistemi.Core.Entities.Task
@using PersonelVeGorevTakipSistemi.Core.Enums
@using TaskState = PersonelVeGorevTakipSistemi.Core.Enums.TaskState

@{
    bool isYönetici = User.IsInRole("Yönetici");
    bool isOverdue = Model.DueDate < DateTime.Today && Model.Status != TaskState.Completed;
}

<div class="card shadow-sm border-0 mb-3 bg-white rounded-3" data-id="@Model.Id">
    <div class="card-body p-3">
        <!-- Kart Üst Kısım: Öncelik ve Yönetici İşlemleri -->
        <div class="d-flex justify-content-between align-items-start mb-2">
            <span>
                @if (Model.Priority == TaskPriority.Low)
                {
                    <span class="badge bg-light text-secondary border" style="font-size: 11px;">Düşük</span>
                }
                else if (Model.Priority == TaskPriority.Medium)
                {
                    <span class="badge bg-warning text-dark" style="font-size: 11px;">Orta</span>
                }
                else if (Model.Priority == TaskPriority.High)
                {
                    <span class="badge bg-danger text-white" style="font-size: 11px;">Yüksek</span>
                }
            </span>

            @if (isYönetici)
            {
                <div class="dropdown">
                    <button class="btn btn-link btn-sm text-secondary p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="box-shadow: none;">
                        <i class="bi bi-three-dots-vertical fs-6"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm">
                        <li>
                            <a class="dropdown-item small" asp-action="Edit" asp-route-id="@Model.Id">
                                <i class="bi bi-pencil me-1"></i> Düzenle
                            </a>
                        </li>
                        <li>
                            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bu görevi silmek istediğinizden emin misiniz?');">
                                <button type="submit" class="dropdown-item text-danger small">
                                    <i class="bi bi-trash me-1"></i> Sil
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
        </div>

        <!-- Görev Başlığı ve Açıklaması -->
        <h6 class="fw-bold text-dark mb-1" style="font-size: 14px;">@Model.Title</h6>
        <p class="text-secondary mb-3" style="font-size: 13px; line-height: 1.4;">
            @(Model.Description.Length > 85 ? Model.Description.Substring(0, 85) + "..." : Model.Description)
        </p>

        <hr class="my-2 opacity-25" />

        <!-- Sorumlu Personel ve Son Teslim Tarihi -->
        <div class="d-flex flex-column gap-1 mb-3" style="font-size: 12px;">
            <div class="d-flex align-items-center text-dark">
                <i class="bi bi-person me-2 text-secondary"></i>
                <span class="fw-semibold">@Model.Employee.FirstName @Model.Employee.LastName</span>
                <span class="text-muted ms-1">(@(Model.Employee.Department?.Name ?? "Departmansız"))</span>
            </div>
            <div class="d-flex align-items-center @(isOverdue ? "text-danger fw-bold" : "text-secondary")">
                <i class="bi bi-calendar-event me-2"></i>
                <span>Son Tarih: @Model.DueDate.ToString("dd.MM.yyyy")</span>
                @if (isOverdue)
                {
                    <span class="badge bg-danger text-white ms-2" style="font-size: 9px;">Gecikti!</span>
                }
            </div>
        </div>

        <!-- Hızlı Durum Butonları -->
        <div class="d-grid">
            @if (Model.Status == TaskState.Pending)
            {
                <form asp-action="UpdateStatus" asp-route-id="@Model.Id" asp-route-status="@TaskState.InProgress" method="post">
                    <button type="submit" class="btn btn-sm btn-outline-warning w-100 py-1 fw-bold text-dark" style="font-size: 11px;">
                        <i class="bi bi-play-fill me-1"></i> Görevi Başlat
                    </button>
                </form>
            }
            else if (Model.Status == TaskState.InProgress)
            {
                <div class="d-flex gap-2">
                    <form asp-action="UpdateStatus" asp-route-id="@Model.Id" asp-route-status="@TaskState.Pending" method="post" class="w-50">
                        <button type="submit" class="btn btn-sm btn-outline-secondary w-100 py-1 fw-bold" style="font-size: 11px;">
                            Durdur
                        </button>
                    </form>
                    <form asp-action="UpdateStatus" asp-route-id="@Model.Id" asp-route-status="@TaskState.Completed" method="post" class="w-50">
                        <button type="submit" class="btn btn-sm btn-outline-success w-100 py-1 fw-bold" style="font-size: 11px;">
                            <i class="bi bi-check-lg me-1"></i> Tamamla
                        </button>
                    </form>
                </div>
            }
            else if (Model.Status == TaskState.Completed)
            {
                <form asp-action="UpdateStatus" asp-route-id="@Model.Id" asp-route-status="@TaskState.InProgress" method="post">
                    <button type="submit" class="btn btn-sm btn-outline-secondary w-100 py-1 fw-bold" style="font-size: 11px;">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Yeniden Aç
                    </button>
                </form>
            }
        </div>
    </div>
</div>
