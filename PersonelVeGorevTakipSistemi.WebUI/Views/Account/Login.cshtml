@model PersonelVeGorevTakipSistemi.WebUI.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - Personel ve Görev Takip Sistemi</title>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
        }
        .login-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            background: rgba(255, 255, 255, 0.95);
            max-width: 400px;
            width: 100%;
            padding: 30px;
        }
        .login-title {
            color: #4a5568;
            font-weight: 700;
            margin-bottom: 5px;
        }
        .login-subtitle {
            color: #718096;
            font-size: 14px;
            margin-bottom: 25px;
        }
        .btn-primary {
            background-color: #764ba2;
            border-color: #764ba2;
            font-weight: 600;
            padding: 10px;
            border-radius: 8px;
            transition: all 0.3s;
        }
        .btn-primary:hover {
            background-color: #667eea;
            border-color: #667eea;
            transform: translateY(-2px);
        }
        .form-control {
            border-radius: 8px;
            padding: 12px;
            border: 1px solid #cbd5e0;
        }
        .form-control:focus {
            border-color: #764ba2;
            box-shadow: 0 0 0 3px rgba(118, 75, 162, 0.25);
        }
        .text-danger {
            font-size: 13px;
        }
    </style>
</head>
<body>

<div class="login-card">
    <div class="text-center">
        <h3 class="login-title">Giriş Yap</h3>
        <p class="login-subtitle">Personel ve Görev Takip Sistemi</p>
    </div>

    <!-- Giriş Formu -->
    <form asp-action="Login" asp-controller="Account" method="post">
        <!-- Genel Model Hata Mesajları (E-posta veya şifre yanlışsa) -->
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-center"></div>

        <!-- E-posta Input -->
        <div class="mb-3">
            <label asp-for="Email" class="form-label text-secondary fw-semibold">E-posta Adresi</label>
            <input asp-for="Email" type="email" class="form-control" placeholder="ad@sirket.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <!-- Şifre Input -->
        <div class="mb-4">
            <label asp-for="Password" class="form-label text-secondary fw-semibold">Şifre</label>
            <input asp-for="Password" class="form-control" placeholder="••••••" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <!-- Giriş Butonu -->
        <div class="d-grid">
            <button type="submit" class="btn btn-primary">Giriş Yap</button>
        </div>
    </form>
</div>

<!-- jQuery ve Bootstrap Validation Kütüphaneleri -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
