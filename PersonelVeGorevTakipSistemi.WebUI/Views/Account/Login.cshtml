@model PersonelVeGorevTakipSistemi.WebUI.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - Personel ve Görev Takip Sistemi</title>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #fdfbf7 0%, #f3ede2 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
        }
        .login-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(69, 62, 52, 0.15);
            background: #ffffff;
            max-width: 400px;
            width: 100%;
            padding: 30px;
        }
        .login-title {
            color: #453e34;
            font-weight: 700;
            margin-bottom: 5px;
        }
        .login-subtitle {
            color: #78716c;
            font-size: 14px;
            margin-bottom: 25px;
        }
        .btn-primary {
            background-color: #d97706;
            border-color: #d97706;
            color: #ffffff;
            font-weight: 600;
            padding: 10px;
            border-radius: 8px;
            transition: all 0.3s;
        }
        .btn-primary:hover {
            background-color: #b45309;
            border-color: #b45309;
            transform: translateY(-2px);
        }
        .form-control {
            border-radius: 8px;
            padding: 12px;
            border: 1px solid #e7e5e4;
            background-color: #fafaf9;
        }
        .form-control:focus {
            border-color: #eab308;
            box-shadow: 0 0 0 3px rgba(234, 179, 8, 0.25);
            background-color: #ffffff;
        }
        .text-danger {
            font-size: 13px;
        }
        /* Hata mesajindaki listeleme noktasini gizlemek icin */
        .text-danger ul {
            list-style-type: none;
            padding: 0;
            margin: 0;
        }
    </style>
</head>
<body>

<div class="login-card">
    <div class="text-center">
        <h3 class="login-title">Giriş Yap</h3>
        <p class="login-subtitle">Personel ve Görev Takip Sistemi</p>
    </div>

    <!-- Giriş Formu -->
    <form asp-action="Login" asp-controller="Account" method="post">
        <!-- Genel Model Hata Mesajları (E-posta veya şifre yanlışsa) -->
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-center"></div>

        <!-- E-posta Input -->
        <div class="mb-3">
            <label asp-for="Email" class="form-label text-secondary fw-semibold">E-posta Adresi</label>
            <input asp-for="Email" type="email" class="form-control" placeholder="ad@sirket.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <!-- Şifre Input -->
        <div class="mb-3">
            <label asp-for="Password" class="form-label text-secondary fw-semibold">Şifre</label>
            <input asp-for="Password" class="form-control" placeholder="••••••" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <!-- Şifremi Unuttum Linki -->
        <div class="mb-4 text-end">
            <a asp-action="ForgotPassword" asp-controller="Account" class="text-decoration-none small" style="color: #d97706;">Şifremi Unuttum</a>
        </div>

        <!-- Giriş Butonları -->
        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-primary">Giriş Yap</button>
            <button type="button" id="quickLoginBtn" class="btn btn-outline-warning text-dark fw-bold border-2">Test Girişi (Yönetici)</button>
        </div>
    </form>
</div>

<!-- jQuery ve Bootstrap Validation Kütüphaneleri -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    $(document).ready(function() {
        $("#quickLoginBtn").click(function() {
            // E-posta ve şifre alanlarını doldur ve formu gönder
            $("input[name='Email']").val("admin@sirket.com");
            $("input[name='Password']").val("123456");
            $("form").submit();
        });
    });
</script>
</body>
</html>
