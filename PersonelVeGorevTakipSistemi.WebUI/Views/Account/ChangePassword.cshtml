@model PersonelVeGorevTakipSistemi.WebUI.Models.ChangePasswordViewModel

@{
    ViewData["Title"] = "Şifre Değiştir";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3 rounded-top-3">
                    <h5 class="card-title mb-0 fw-bold">Şifre Değiştir</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ChangePassword" asp-controller="Account" method="post">
                        <!-- Model Hata Mesajları -->
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Eski Şifre -->
                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label fw-semibold text-secondary">Eski Şifre</label>
                            <input asp-for="CurrentPassword" type="password" class="form-control py-2" placeholder="Mevcut şifrenizi girin" />
                            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                        </div>

                        <!-- Yeni Şifre -->
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-semibold text-secondary">Yeni Şifre</label>
                            <input asp-for="NewPassword" type="password" class="form-control py-2" placeholder="En az 6 karakter girin" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <!-- Yeni Şifre Tekrarı -->
                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold text-secondary">Yeni Şifre Tekrarı</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control py-2" placeholder="Yeni şifrenizi tekrar girin" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <!-- Butonlar -->
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary px-4 py-2">İptal</a>
                            <button type="submit" class="btn btn-primary px-4 py-2">Şifreyi Güncelle</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
