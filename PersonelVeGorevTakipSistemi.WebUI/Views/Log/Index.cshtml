@{
    ViewData["Title"] = "Özel Sistem Günlükleri";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-dark text-white py-3 rounded-top-3">
            <h5 class="card-title mb-0 fw-bold">
                <i class="bi bi-shield-lock-fill text-warning me-2"></i> Özel Sistem Günlükleri (Loglar)
            </h5>
        </div>
        <div class="card-body p-4 text-center">
            <div class="py-5">
                <i class="bi bi-clock-history text-muted" style="font-size: 4rem;"></i>
                <h4 class="fw-bold text-dark mt-3">Sistem Log İzleme Ekranı</h4>
                <p class="text-secondary col-md-8 mx-auto mt-2">
                    Bu panel, yalnızca <strong>Yönetici</strong> yetkisine sahip kullanıcıların görebileceği ve doğrudan <code>/Log</code> adresi üzerinden erişilebilen gizli bir alandır. Üst menüde (Navbar) bağlantısı bulunmaz.
                </p>
                <div class="alert alert-warning border-0 col-md-6 mx-auto mt-4" role="alert">
                    <i class="bi bi-info-circle-fill me-2"></i> <strong>Staj Yol Haritası Bilgisi:</strong> Bu modül ve loglama veri altyapısı <strong>7. Hafta</strong> çalışmaları kapsamında aktif hale getirilecektir.
                </div>
                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark px-4 py-2">
                        Dashboard'a Geri Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
