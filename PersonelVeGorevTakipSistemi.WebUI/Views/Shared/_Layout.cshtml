<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PersonelVeGorevTakipSistemi.WebUI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PersonelVeGorevTakipSistemi.WebUI.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-briefcase-fill text-warning me-2"></i>Personel ve Görev Takip
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Yönetici"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Department" asp-action="Index">Departmanlar</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Employee" asp-action="Index">Personeller</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Task" asp-action="Index">Görevler</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Log" asp-action="Index">İşlem Günlükleri</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Task" asp-action="Index">Görevlerim</a>
                                </li>
                            }
                        }
                    </ul>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown profile-dropdown">
                                @{
                                    string userName = User.Identity.Name ?? "";
                                    string[] parts = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                    string uInitials = parts.Length >= 2 ? (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper() : (userName.Length >= 2 ? userName.Substring(0, 2).ToUpper() : "U");
                                }
                                <a class="nav-link dropdown-toggle text-white fw-semibold d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="user-avatar user-avatar-sm me-2" style="background: linear-gradient(135deg, #eab308 0%, #d97706 100%); color: #1c1a18;">@uInitials</span>
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-2" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item small text-dark" asp-controller="Account" asp-action="ChangePassword">
                                            <i class="bi bi-shield-lock me-2 text-secondary"></i> Şifre Değiştir
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider opacity-25"></li>
                                    <li>
                                        <a class="dropdown-item text-danger small" asp-controller="Account" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2 text-danger"></i> Çıkış Yap
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3">
        <div class="container text-center small text-secondary">
            &copy; 2026 Personel ve Görev Takip Sistemi. Tüm Hakları Saklıdır.
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.IsInRole("Yönetici"))
    {
        <!-- DUYURU EKLEME MODALI -->
        <div class="modal fade" id="announcementModal" tabindex="-1" aria-labelledby="announcementModalLabel" aria-hidden="true" data-bs-backdrop="static">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <form asp-action="Create" asp-controller="Announcement" method="post">
                        <div class="modal-header bg-dark text-white">
                            <h5 class="modal-title fw-bold" id="announcementModalLabel">
                                <i class="bi bi-megaphone me-2 text-warning"></i>Yeni Duyuru Yayınla
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
                        </div>
                        <div class="modal-body text-start">
                            <div class="mb-3">
                                <label class="form-label fw-bold text-dark">Duyuru Başlığı</label>
                                <input type="text" name="title" class="form-control" placeholder="Örn: Cuma Günü Sistem Bakımı" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold text-dark">Duyuru İçeriği</label>
                                <textarea name="content" class="form-control" rows="3" placeholder="Duyurunun detaylarını buraya yazınız..." required></textarea>
                            </div>
                        </div>
                        <div class="modal-footer bg-light">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                            <button type="submit" class="btn btn-warning fw-bold px-4">Yayınla</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script>
            function openAnnouncementModal() {
                var modalEl = document.getElementById('announcementModal');
                if (modalEl) {
                    var modalInstance = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                    modalInstance.show();
                }
            }
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
