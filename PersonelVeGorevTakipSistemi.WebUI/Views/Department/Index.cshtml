@model List<PersonelVeGorevTakipSistemi.Core.Entities.Department>

@{
    ViewData["Title"] = "Departman Listesi";
}

<div class="container mt-4">
    <!-- Baslik ve Yeni Ekle Butonu -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">Departmanlar</h2>
        <a asp-action="Create" asp-controller="Department" class="btn btn-primary px-4 py-2">
            <i class="bi bi-plus-circle me-1"></i> Yeni Departman Ekle
        </a>
    </div>

    <!-- Basari veya Hata Mesajlari -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <!-- Departman Tablosu -->
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3 px-4" style="width: 8%;">ID</th>
                            <th class="py-3" style="width: 22%;">Departman Adı</th>
                            <th class="py-3" style="width: 35%;">Açıklama</th>
                            <th class="py-3 text-center" style="width: 15%;">Personel Sayısı</th>
                            <th class="py-3 px-4 text-end" style="width: 20%;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-secondary">
                                    Kayıtlı departman bulunamadı.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 fw-semibold text-secondary">#@item.Id</td>
                                    <td class="fw-semibold text-dark">@item.Name</td>
                                    <td class="text-secondary">@item.Description</td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border px-2.5 py-1.5 fw-bold">
                                            <i class="bi bi-people me-1 text-primary"></i> @(item.Employees?.Count ?? 0) Çalışan
                                        </span>
                                    </td>
                                    <td class="px-4 text-end">
                                        <div class="d-inline-flex align-items-center justify-content-end gap-1">
                                            <!-- İncele Butonu -->
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Departman Çalışanlarını Gör">
                                                <i class="bi bi-eye me-1"></i> İncele
                                            </a>
                                            <!-- Duzenle Butonu -->
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                                Düzenle
                                            </a>
                                            <!-- Sil Butonu (Guvenlik icin POST form icinde) -->
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline m-0" onsubmit="return confirm('Bu departmanı silmek istediğinizden emin misiniz?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    Sil
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
