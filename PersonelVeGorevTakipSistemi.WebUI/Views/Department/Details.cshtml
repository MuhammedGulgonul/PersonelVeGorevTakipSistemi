@model PersonelVeGorevTakipSistemi.Core.Entities.Department

@{
    ViewData["Title"] = Model.Name + " - Departman Detayları ve Çalışanlar";
}

<div class="container mt-4">
    <!-- Üst Gezinme ve Butonlar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary px-3">
            <i class="bi bi-arrow-left me-1"></i> Departmanlara Dön
        </a>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-3">
                <i class="bi bi-pencil-square me-1"></i> Departmanı Düzenle
            </a>
        </div>
    </div>

    <!-- Departman Bilgi Kartı -->
    <div class="card shadow-sm border-0 rounded-3 mb-4 bg-white">
        <div class="card-body p-4">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <span class="badge bg-primary text-white mb-2" style="font-size: 12px;">DEPARTMAN DETAYI</span>
                    <h3 class="fw-bold text-dark mb-1">@Model.Name</h3>
                    <p class="text-secondary mb-0">@(string.IsNullOrWhiteSpace(Model.Description) ? "Departman açıklaması girilmemiştir." : Model.Description)</p>
                </div>
                <div class="text-end">
                    <span class="display-6 fw-bold text-primary">@(Model.Employees?.Count ?? 0)</span>
                    <span class="d-block text-secondary small">Kayıtlı Çalışan</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Departmandaki Çalışanlar Listesi -->
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-light py-3 border-0 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold text-dark mb-0">
                <i class="bi bi-people-fill me-2 text-primary"></i> Departmandaki Çalışanlar (@(Model.Employees?.Count ?? 0))
            </h5>
            <a asp-controller="Employee" asp-action="Create" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-person-plus me-1"></i> Yeni Personel Ekle
            </a>
        </div>
        <div class="card-body p-0">
            @if (Model.Employees == null || !Model.Employees.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-person-badge text-secondary" style="font-size: 3rem;"></i>
                    <h5 class="fw-bold text-dark mt-3">Bu Departmanda Henüz Çalışan Bulunmuyor</h5>
                    <p class="text-secondary small">Departmana personel atamak için Personeller sayfasından yeni kayıt oluşturabilir veya var olan personelleri düzenleyebilirsiniz.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="py-3 px-4" style="width: 8%;">ID</th>
                                <th class="py-3" style="width: 25%;">Adı Soyadı</th>
                                <th class="py-3" style="width: 25%;">E-posta</th>
                                <th class="py-3" style="width: 17%;">Ünvan</th>
                                <th class="py-3" style="width: 12%;">Rol</th>
                                <th class="py-3" style="width: 8%;">Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in Model.Employees)
                            {
                                string eIn1 = !string.IsNullOrEmpty(emp.FirstName) ? emp.FirstName.Substring(0, 1) : "";
                                string eIn2 = !string.IsNullOrEmpty(emp.LastName) ? emp.LastName.Substring(0, 1) : "";
                                string eInitials = (eIn1 + eIn2).ToUpper();

                                <tr>
                                    <td class="px-4 fw-semibold text-secondary">#@emp.Id</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <span class="user-avatar user-avatar-md me-2">@eInitials</span>
                                            <div>
                                                <div class="fw-bold text-dark">@emp.FirstName @emp.LastName</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-secondary">@emp.Email</td>
                                    <td class="text-secondary">@(string.IsNullOrWhiteSpace(emp.Title) ? "Belirtilmemiş" : emp.Title)</td>
                                    <td>
                                        <span class="badge @(emp.Role == "Yönetici" ? "bg-dark" : "bg-secondary")">
                                            @emp.Role
                                        </span>
                                    </td>
                                    <td>
                                        @if (emp.IsActive)
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Pasif</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
