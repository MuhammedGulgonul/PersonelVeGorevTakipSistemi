@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-4">
    <!-- Şifre değiştirme veya benzeri işlemlerden gelen başarı mesajı -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border-0">
        <div class="container-fluid py-5">
            <h1 class="display-5 fw-bold text-dark">Hoş Geldiniz!</h1>
            <p class="col-md-8 fs-4 text-secondary mt-3">
                Sayın <strong>@User.Identity.Name</strong>, sisteme başarıyla giriş yaptınız.
            </p>
            <hr class="my-4">
            
            <div class="mt-4">
                @if (User.IsInRole("Yönetici"))
                {
                    <h5 class="fw-bold text-primary mb-3">Yönetici Paneli Kılavuzu</h5>
                    <p class="text-secondary">
                        Sistem yöneticisi (Admin) yetkilerine sahipsiniz. Üst menüyü kullanarak şu işlemleri gerçekleştirebilirsiniz:
                    </p>
                    <div class="row g-3 mt-2">
                        <div class="col-md-6 col-lg-3">
                            <div class="p-3 bg-white rounded border shadow-xs h-100">
                                <h6 class="fw-bold text-dark mb-2">Departman Yönetimi</h6>
                                <p class="small text-muted mb-0">Departman ekleyin, güncelleyin veya silin.</p>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="p-3 bg-white rounded border shadow-xs h-100">
                                <h6 class="fw-bold text-dark mb-2">Personel Yönetimi</h6>
                                <p class="small text-muted mb-0">Yeni çalışan kaydedin ve aktiflik durumlarını yönetin.</p>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="p-3 bg-white rounded border shadow-xs h-100">
                                <h6 class="fw-bold text-dark mb-2">Görev Yönetimi</h6>
                                <p class="small text-muted mb-0">Görev oluşturun, çalışanlara atayın ve takip edin.</p>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="p-3 bg-white rounded border shadow-xs h-100">
                                <h6 class="fw-bold text-dark mb-2">Hata Kayıtları (Log)</h6>
                                <p class="small text-muted mb-0">Sistemde oluşan teknik hataları inceleyin.</p>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <h5 class="fw-bold text-success mb-3">Çalışan Paneli Kılavuzu</h5>
                    <p class="text-secondary">
                        Personel yetkileriyle sisteme bağlısınız. Üst menüden **Görevlerim** sekmesine giderek:
                    </p>
                    <ul class="text-secondary">
                        <li>Size atanan güncel görevlerin listesini görebilirsiniz.</li>
                        <li>Görevlerin durumunu (Beklemede, Devam Ediyor, Tamamlandı) güncelleyebilirsiniz.</li>
                        <li>Görev detaylarından ilgili dosya eklerini (PDF/Resim) inceleyebilirsiniz.</li>
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
