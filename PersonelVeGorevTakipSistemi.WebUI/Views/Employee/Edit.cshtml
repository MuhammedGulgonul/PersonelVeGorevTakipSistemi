@model PersonelVeGorevTakipSistemi.Core.Entities.Employee

@{
    ViewData["Title"] = "Personel Düzenle";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3 rounded-top-3">
                    <h5 class="card-title mb-0 fw-bold">Personel Düzenle</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" asp-controller="Employee" method="post">
                        <!-- Model Hatalari -->
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Gizli Id Alani -->
                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <!-- Ad -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label fw-semibold text-secondary">Adı</label>
                                <input asp-for="FirstName" class="form-control py-2" required placeholder="Örn: Mehmet" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>

                            <!-- Soyad -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label fw-semibold text-secondary">Soyadı</label>
                                <input asp-for="LastName" class="form-control py-2" required placeholder="Örn: Demir" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <!-- E-posta -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-semibold text-secondary">E-posta Adresi</label>
                                <input asp-for="Email" type="email" class="form-control py-2" required placeholder="ad@sirket.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <!-- Sifre Duzenleme (Istege Bagli) -->
                            <div class="col-md-6 mb-3">
                                <label for="newPassword" class="form-label fw-semibold text-secondary">Yeni Şifre (Değiştirmek istemiyorsanız boş bırakın)</label>
                                <input id="newPassword" name="newPassword" type="password" class="form-control py-2" placeholder="••••••" />
                            </div>
                        </div>

                        <div class="row">
                            <!-- Ünvan -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Title" class="form-label fw-semibold text-secondary">Ünvan / Görevi</label>
                                <input asp-for="Title" class="form-control py-2" required placeholder="Örn: Yazılım Mühendisi" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <!-- Departman Secimi -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="DepartmentId" class="form-label fw-semibold text-secondary">Departman</label>
                                <select asp-for="DepartmentId" class="form-select py-2" required>
                                    @if (ViewBag.Departments != null)
                                    {
                                        foreach (var dept in ViewBag.Departments)
                                        {
                                            <option value="@dept.Id" selected="@(dept.Id == Model.DepartmentId ? "selected" : null)">@dept.Name</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Rol Secimi -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Role" class="form-label fw-semibold text-secondary">Sistem Rolü</label>
                                <select asp-for="Role" class="form-select py-2" required>
                                    <option value="Çalışan" selected="@(Model.Role == "Çalışan" ? "selected" : null)">Çalışan</option>
                                    <option value="Yönetici" selected="@(Model.Role == "Yönetici" ? "selected" : null)">Yönetici</option>
                                </select>
                                <span asp-validation-for="Role" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Aktiflik Durumu Checkbox -->
                        <div class="mb-4 form-check ms-1">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold text-secondary">Personel Aktif</label>
                        </div>

                        <!-- Butonlar -->
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2">İptal</a>
                            <button type="submit" class="btn btn-primary px-4 py-2">Güncelle</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
